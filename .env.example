# =============================================================================
# SECURE AI CHATBOT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# OpenAI API Key - Required for GPT-4 chat completions
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Flask Secret Key - Used for session signing
# Generate a strong random key with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-super-secret-flask-key-change-this-in-production

# Database Path (Optional - defaults to chatbot.db in project root)
# DATABASE_PATH=/path/to/your/chatbot.db

# Flask Environment (development or production)
# FLASK_ENV=production

# Rate Limiting Storage (Use Redis in production for multi-server deployments)
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
